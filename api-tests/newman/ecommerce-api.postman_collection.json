    {
      "name": "Payment",
      "item": [
        {
          "name": "POST /payment/charge - success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"cardNumber\": \"4111111111111111\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payment/charge",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payment",
                "charge"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// If orderId is not set, create an order first",
                  "if (!pm.collectionVariables.get(\"orderId\")) {",
                  "  pm.sendRequest({",
                  "    url: pm.environment.get(\"baseUrl\") + \"/cart/clear\",",
                  "    method: \"POST\",",
                  "    header: { \"Authorization\": \"Bearer \" + pm.collectionVariables.get(\"accessToken\") }",
                  "  }, function () {",
                  "    pm.sendRequest({",
                  "      url: pm.environment.get(\"baseUrl\") + \"/cart/add\",",
                  "      method: \"POST\",",
                  "      header: {",
                  "        \"Content-Type\": \"application/json\",",
                  "        \"Authorization\": \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "      },",
                  "      body: { mode: \"raw\", raw: JSON.stringify({ productId: 1, quantity: 1 }) }",
                  "    }, function () {",
                  "      pm.sendRequest({",
                  "        url: pm.environment.get(\"baseUrl\") + \"/order/create\",",
                  "        method: \"POST\",",
                  "        header: {",
                  "          \"Content-Type\": \"application/json\",",
                  "          \"Authorization\": \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "        },",
                  "        body: { mode: \"raw\", raw: \"{}\" }",
                  "      }, function (err, res) {",
                  "        if (!err) {",
                  "          pm.collectionVariables.set(\"orderId\", res.json().orderId);",
                  "        }",
                  "      });",
                  "    });",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Payment success schema\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property(\"orderId\");",
                  "  pm.expect(json).to.have.property(\"status\", \"PAID\");",
                  "});",
                  "",
                  "pm.test(\"Payment response under 500ms\", function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },

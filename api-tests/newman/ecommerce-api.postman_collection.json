      "name": "Order",
      "item": [
        {
          "name": "POST /order/create - from cart items",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/order/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "order",
                "create"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Ensure clean cart and add an item before creating order",
                  "pm.sendRequest({",
                  "  url: pm.environment.get(\"baseUrl\") + \"/cart/clear\",",
                  "  method: \"POST\",",
                  "  header: { \"Authorization\": \"Bearer \" + pm.collectionVariables.get(\"accessToken\") }",
                  "}, function () {",
                  "  pm.sendRequest({",
                  "    url: pm.environment.get(\"baseUrl\") + \"/cart/add\",",
                  "    method: \"POST\",",
                  "    header: {",
                  "      \"Content-Type\": \"application/json\",",
                  "      \"Authorization\": \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "    },",
                  "    body: { mode: \"raw\", raw: JSON.stringify({ productId: 1, quantity: 2 }) }",
                  "  }, function () {});",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Order create response structure\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property(\"message\", \"Order created\");",
                  "  pm.expect(json).to.have.property(\"orderId\");",
                  "  pm.expect(json.orderId).to.be.a(\"string\");",
                  "  pm.expect(json).to.have.property(\"total\");",
                  "});",
                  "",
                  "pm.test(\"Order create under 500ms\", function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "// Save orderId for payment tests",
                  "pm.collectionVariables.set(\"orderId\", pm.response.json().orderId);"
                ],
                "type": "text/javascript"
              }
            }
